<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>NexusStream | Agent-Powered Media</title>
  <link href="https://fonts.googleapis.com/css2?family=Exo+2:wght@300;400;600&family=Orbitron:wght@500;700&display=swap" rel="stylesheet">
  <style>
    :root { --cyan: #00f3ff; --purple: #7b2cbf; --dark: #0a0e17; --glass: rgba(255,255,255,0.08); --border: rgba(0,243,255,0.3); }
    * { margin:0; padding:0; box-sizing:border-box; }
    body { font-family:'Exo 2',sans-serif; background:var(--dark); color:#fff; overflow-x:hidden; line-height:1.5; }
    #bg { position:fixed; top:0; left:0; width:100%; height:100%; z-index:-1; background:radial-gradient(ellipse at bottom, #1a1a2e 0%, var(--dark) 70%); }
    .p { position:absolute; border-radius:50%; background:var(--cyan); animation:f 15s infinite linear; opacity:0.3; }
    @keyframes f { 0%{transform:translateY(0);opacity:0.3} 50%{opacity:0.6} 100%{transform:translateY(-100vh) translateX(30px);opacity:0.2} }
    header { padding:1rem 1.5rem; display:flex; justify-content:space-between; align-items:center; border-bottom:1px solid var(--border); backdrop-filter:blur(10px); position:sticky; top:0; z-index:100; background:rgba(10,14,23,0.9); }
    .logo { font-family:'Orbitron',sans-serif; font-size:1.6rem; font-weight:700; background:linear-gradient(90deg,var(--cyan),var(--purple)); -webkit-background-clip:text; -webkit-text-fill-color:transparent; }
    nav a { color:#ddd; text-decoration:none; margin-left:1.2rem; font-size:0.9rem; transition:color 0.2s; }
    nav a:hover { color:var(--cyan); }
    .hero { text-align:center; padding:2rem 1rem; }
    .hero h1 { font-family:'Orbitron',sans-serif; font-size:2rem; margin-bottom:0.5rem; }
    .hero p { color:#aaa; font-size:0.9rem; }
    #token-widget { position:fixed; top:15px; right:20px; background:var(--glass); border:1px solid var(--cyan); border-radius:50px; padding:0.5rem 1.2rem; display:flex; align-items:center; gap:8px; cursor:pointer; z-index:150; }
    .grid { max-width:1100px; margin:0 auto; padding:1.5rem; display:grid; gap:1.5rem; grid-template-columns:1fr 1fr; }
    .panel { background:var(--glass); border:1px solid var(--border); border-radius:16px; padding:1.2rem; }
    .panel h2 { margin-bottom:1rem; font-size:1.1rem; display:flex; align-items:center; gap:8px; }
    .cards { display:grid; grid-template-columns:repeat(auto-fill, minmax(180px, 1fr)); gap:1rem; }
    .card { background:rgba(255,255,255,0.04); border:1px solid rgba(0,243,255,0.15); border-radius:12px; overflow:hidden; transition:transform 0.2s; cursor:pointer; }
    .card:hover { transform:translateY(-4px); box-shadow:0 8px 20px rgba(0,0,0,0.3); }
    .card img { width:100%; height:100px; object-fit:cover; background:#111; }
    .card-body { padding:0.7rem; }
    .card-title { font-weight:600; font-size:0.85rem; margin-bottom:0.3rem; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    .meta { font-size:0.7rem; color:#888; display:flex; justify-content:space-between; }
    .actions { display:flex; gap:0.5rem; margin-top:0.6rem; }
    .btn { flex:1; border:none; padding:0.4rem; border-radius:6px; font-size:0.75rem; cursor:pointer; transition:0.2s; }
    .btn-primary { background:var(--cyan); color:var(--dark); font-weight:600; }
    .btn-sec { background:var(--purple); color:#fff; }
    .modal { display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.85); z-index:200; align-items:center; justify-content:center; padding:1rem; }
    .modal.active { display:flex; }
    .modal-content { background:var(--dark); border:1px solid var(--border); border-radius:16px; padding:1.5rem; max-width:400px; width:100%; position:relative; text-align:center; }
    .close { position:absolute; top:10px; right:15px; font-size:1.5rem; cursor:pointer; color:#888; }
    .close:hover { color:var(--cyan); }
    .sync-box { background:linear-gradient(145deg, #121218, #0f0f16); border:2px solid var(--cyan); border-radius:16px; padding:1.5rem; max-width:450px; width:90%; text-align:center; }
    .sync-img { width:100%; height:160px; object-fit:contain; background:#000; border-radius:10px; margin:0.5rem 0; }
    .progress { height:6px; background:#222; border-radius:3px; margin:1rem 0; overflow:hidden; }
    .bar { height:100%; width:0%; background:linear-gradient(90deg, var(--cyan), var(--purple)); transition:width 0.1s linear; }
    .sync-btn { width:100%; padding:0.9rem; border:2px solid var(--cyan); background:transparent; color:var(--cyan); font-family:'Orbitron'; border-radius:10px; cursor:pointer; margin-top:1rem; user-select:none; }
    .sync-btn:active { background:var(--cyan); color:var(--dark); }
    #admin-panel { display:none; max-width:1000px; margin:2rem auto; background:var(--glass); border:1px solid #ff4444; border-radius:12px; padding:1.5rem; }
    .tabs { display:flex; gap:1rem; margin-bottom:1rem; border-bottom:1px solid #333; padding-bottom:0.5rem; }
    .tab { background:none; border:none; color:#aaa; cursor:pointer; padding:0.3rem 0.8rem; }
    .tab.active { color:var(--cyan); border-bottom:2px solid var(--cyan); }
    .tab-content { display:none; }
    .tab-content.active { display:block; }
    table { width:100%; border-collapse:collapse; margin-top:1rem; font-size:0.8rem; }
    th, td { padding:0.6rem; border-bottom:1px solid #333; text-align:left; }
    th { color:var(--cyan); }
    input, select { width:100%; padding:0.5rem; background:#111; border:1px solid #444; border-radius:6px; color:#fff; margin:0.3rem 0; }
    .log-row { font-family:monospace; font-size:0.75rem; color:#999; padding:0.3rem 0; border-bottom:1px dashed #333; }
    .loader { text-align:center; padding:1.5rem; color:var(--cyan); font-family:'Orbitron'; }
    .empty { text-align:center; padding:1.5rem; color:#777; }
    .toast { position:fixed; bottom:20px; left:50%; transform:translateX(-50%); background:var(--dark); border:1px solid var(--cyan); padding:0.7rem 1.2rem; border-radius:8px; z-index:300; opacity:0; transition:0.3s; pointer-events:none; }
    .toast.show { opacity:1; transform:translateX(-50%) translateY(-10px); }
    @media(max-width:800px) { .grid { grid-template-columns:1fr; } nav { display:none; } .hero h1 { font-size:1.5rem; } }
  </style>
</head>
<body>
  <div id="bg"></div>
  <header><div class="logo">NEXUSSTREAM</div><nav><a href="#movies">Movies</a><a href="#trailers">Trailers</a></nav></header>
  <div class="hero"><h1>Stream. Sync. Unlock.</h1><p>Agent-powered ad discovery • Treasury management • 5 Tokens on signup</p></div>
  <div id="token-widget" onclick="openVault()"><span>🔹</span><span id="t-count" style="font-family:'Orbitron'; font-weight:700;">0</span></div>

  <div class="grid">
    <div class="panel" id="movies"><h2 style="color:var(--cyan);">🎥 Full Movies</h2><div class="cards" id="m-cards"><div class="loader">Loading...</div></div></div>
    <div class="panel" id="trailers"><h2 style="color:var(--purple);">🎞️ Trailers</h2><div class="cards" id="t-cards"><div class="loader">Loading...</div></div></div>
  </div>

  <div id="auth-modal" class="modal"><div class="modal-content"><span class="close" onclick="closeModal('auth-modal')">&times;</span><h2 style="color:var(--cyan); margin-bottom:0.5rem;">✨ Join NexusStream</h2><p style="color:#999; font-size:0.8rem; margin-bottom:1rem;">Phone + Password. 5 Tokens + 30 Days Free.</p><input id="a-phone" type="tel" placeholder="Phone number"><input id="a-pass" type="password" placeholder="Password"><button class="btn btn-primary" style="margin-top:0.8rem;" onclick="register()">Create Account</button></div></div>
  <div id="sync-modal" class="modal"><div class="sync-box"><span class="close" onclick="abortSync()" style="color:#888;">&times;</span><h3 style="color:var(--cyan); font-family:'Orbitron'; margin-bottom:0.5rem;">⚡ DATA SYNC</h3><p style="color:#aaa; font-size:0.8rem;">Hold to calibrate & earn tokens</p><img id="sync-img" class="sync-img" src="" alt="Ad"><div class="progress"><div id="sync-bar" class="bar"></div></div><div id="sync-timer" style="font-family:'Orbitron'; color:var(--cyan); margin-bottom:0.5rem;">0.0s / 5.0s</div><button id="sync-btn" class="sync-btn">HOLD TO SYNC</button></div></div>
  <div id="vault-modal" class="modal"><div class="modal-content"><span class="close" onclick="closeModal('vault-modal')">&times;</span><h2 style="color:var(--cyan); margin-bottom:0.5rem;">🔹 Token Vault</h2><div style="font-size:2rem; font-family:'Orbitron'; margin:0.8rem 0;" id="v-count">0</div><button class="btn btn-primary" onclick="claimDaily()" style="margin-bottom:0.5rem;">🌅 Claim Daily Bonus (+2)</button><button class="btn btn-sec" onclick="closeModal('vault-modal')">Close</button></div></div>
  <div id="video-modal" class="modal"><div class="modal-content" style="max-width:800px; padding:0; overflow:hidden; border:2px solid var(--cyan);"><span class="close" onclick="closeModal('video-modal')" style="color:#000; background:rgba(255,255,255,0.2); border-radius:50%; width:30px; height:30px; display:flex; align-items:center; justify-content:center;">&times;</span><iframe id="yt-frame" src="" style="width:100%; aspect-ratio:16/9; border:none; display:block;" allowfullscreen></iframe></div></div>

  <div id="admin-panel">
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1rem;"><h3 style="color:var(--cyan);">🕵️ Agent & Treasury Hub</h3><button class="btn btn-sec" onclick="document.getElementById('admin-panel').style.display='none'">Hide</button></div>
    <div class="tabs"><button class="tab active" onclick="switchTab('treasury')">Treasury</button><button class="tab" onclick="switchTab('leads')">Ad Leads</button><button class="tab" onclick="switchTab('logs')">Agent Logs</button></div>
    <div id="treasury-tab" class="tab-content active"><div style="display:grid; grid-template-columns:1fr 1fr; gap:1rem;"><div style="background:#111; padding:1rem; border-radius:8px;"><div style="color:#888; font-size:0.8rem;">Platform Balance</div><div id="treasury-balance" style="font-size:1.8rem; font-family:'Orbitron'; color:var(--cyan);">$0.00</div></div><div style="background:#111; padding:1rem; border-radius:8px;"><div style="color:#888; font-size:0.8rem;">Manual Deposit</div><div style="display:flex; gap:0.5rem;"><input id="deposit-amount" type="number" placeholder="Amount"><button class="btn btn-primary" onclick="deposit()">Deposit</button></div></div></div><